<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Neon Animation</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
display:flex;
justify-content:center;
align-items:center;
height:100vh;
background:#000;
overflow:hidden;
}

h1{
font-size:70px;
color:#fff;
text-transform:uppercase;
letter-spacing:8px;
animation:glow 2s ease-in-out infinite alternate;
}

@keyframes glow{
0%{
text-shadow:0 0 10px #00ffff,
0 0 20px #00ffff,
0 0 40px #00ffff;
}

100%{
text-shadow:0 0 20px #ff00ff,
0 0 40px #ff00ff,
0 0 80px #ff00ff;
}
}
</style>

</head>

<body>

<h1>Hello World</h1>

</body>
</html>